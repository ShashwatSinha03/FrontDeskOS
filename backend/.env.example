# FrontDeskOS Backend - Environment Variables Configuration

# Server
PORT=4000
NODE_ENV=development

# Database (Supabase Postgres)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/frontdeskos
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# AI Provider Abstraction Configurations
# Active Provider: groq, openai, or anthropic
LLM_PROVIDER=groq

# Groq Credentials
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI Credentials (Future Proofing)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic/Claude Credentials (Future Proofing)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20240620

# Admin Dashboard Auth
ADMIN_API_KEY=dev-api-key-change-in-production
