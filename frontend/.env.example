# FrontDeskOS Frontend - Environment Variables Configuration

# Next.js Server Port (Default is 3000)
PORT=3000

# Express Backend Integration URL
NEXT_PUBLIC_API_URL=https://frontdeskos.onrender.com/api

# Client-Side Supabase Configurations (Future proofing)
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Admin API Key (must match backend ADMIN_API_KEY)
ADMIN_API_KEY=fdos_adm_8a3f9c2e1b7d4f6a8c0e2d4b6a8c0e2d
